# Copy to .env (only needed if you want to refresh data locally).

# Email for OpenAlex polite pool — uses this project's contact by default.
OPENALEX_MAILTO=info@forrt.org

# Google service-account JSON (single-line) for reading the private Tenzing
# index sheet. Leave unset to use the gws CLI (interactive, dev only) or the
# committed data/contributors.csv cache.
# GSHEET_CREDENTIALS={"type":"service_account", ...}
